#!/bin/bash

set -euo pipefail
trap 'exit 1' INT

BUILD=0
CLEAN=0
IMAGE_NAME="localhost/claude-container_claude-auth-workspace"

usage() {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS] <directory>

Launch a containerized Claude workspace in the given directory.

Options:
  -b, --build    Force a rebuild of the container image
  --clean        Remove the container image and dangling images, then exit
  -h, --help     Show this help message and exit
EOF
}

# Parse arguments
POSITIONAL_ARGS=()
while [[ $# -gt 0 ]]; do
  case $1 in
    -b|--build)
      BUILD=1
      shift
      ;;
    --clean)
      CLEAN=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      POSITIONAL_ARGS+=("$1")
      shift
      ;;
  esac
done

RUN_DIR="$( cd "$(dirname "$( readlink "$0" || ls -1 "$0" )")" > /dev/null && pwd -P )"

if [[ $CLEAN -eq 1 ]]; then
  echo "Removing image: $IMAGE_NAME"
  podman rmi "$IMAGE_NAME" 2>/dev/null && echo "Removed." || echo "Image not found, skipping."
  echo "Removing network: claude-container_default"
  podman network rm claude-container_default 2>/dev/null && echo "Removed." || echo "Network not found, skipping."
  echo "Removing staged build context: $RUN_DIR/.build-context"
  rm -rf "$RUN_DIR/.build-context" && echo "Removed." || echo "Not found, skipping."
  echo "Pruning dangling images..."
  podman image prune -f
  exit 0
fi

set -- ${POSITIONAL_ARGS[@]+"${POSITIONAL_ARGS[@]}"}

if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

echo "RUN DIR: $RUN_DIR"

WORKING_DIR=$( cd "$1" > /dev/null && pwd )
cd "$WORKING_DIR" || exit 1

# プロジェクトの .claude-container ファイルがあれば KEY=VALUE 行のみ環境変数として取り込む。
# source だと利用側プロジェクトのファイルがホスト上で任意コード実行できてしまうため、
# 変数代入以外の行は無視する（値は最初の = 以降の生文字列。クォート・展開は解釈しない）。
if [[ -f "$WORKING_DIR/.claude-container" ]]; then
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[A-Za-z_][A-Za-z0-9_]*= ]] || continue
    # shellcheck disable=SC2163  # 変数名でなく KEY=VALUE 文字列の export が意図
    export "$line"
  done < "$WORKING_DIR/.claude-container"
fi

# プロジェクト側の apt/pip パッケージ上書き設定ディレクトリ
PROJECT_CONF_DIR="$WORKING_DIR/.claude-container.d"
# ビルドコンテキストのステージング先。mktemp のようなランダムパスは使わず固定パスにすることで、
# ビルドキャッシュを安定させ、trap によるクリーンアップも不要にする。
BUILD_CONTEXT_DIR="$RUN_DIR/.build-context"

# entrypoint.sh / init-firewall.sh / packages.txt / requirements.txt / allowed-domains.txt を
# ビルドコンテキストへ集約する。packages.txt・requirements.txt・allowed-domains.txt は
# プロジェクト側の .claude-container.d/ にあればそちらを、
# なければ claude-container 同梱のデフォルト（空のフォールバック）を使う。
stage_build_context() {
  mkdir -p "$BUILD_CONTEXT_DIR"
  cp "$RUN_DIR/entrypoint.sh" "$BUILD_CONTEXT_DIR/entrypoint.sh"
  cp "$RUN_DIR/init-firewall.sh" "$BUILD_CONTEXT_DIR/init-firewall.sh"

  local file
  for file in packages.txt requirements.txt allowed-domains.txt; do
    if [[ -f "$PROJECT_CONF_DIR/$file" ]]; then
      cp "$PROJECT_CONF_DIR/$file" "$BUILD_CONTEXT_DIR/$file"
    else
      cp "$RUN_DIR/$file" "$BUILD_CONTEXT_DIR/$file"
    fi
  done
}

# compose がビルドコンテキストとして参照するため、ディレクトリ自体は常に存在させる
mkdir -p "$BUILD_CONTEXT_DIR"

# -b 指定時、またはイメージが未ビルドのときのみステージングを実行する
# （podman image exists が使えない古い podman では `podman images -q` ベースの判定に読み替える）
if [[ $BUILD -eq 1 ]] || ! podman image exists "$IMAGE_NAME" 2>/dev/null; then
  stage_build_context
fi

# ホストのタイムゾーンを自動検出（.env で上書き済みでなければ設定）
if [[ -z "${TZ:-}" ]]; then
  if [[ -f /etc/timezone ]]; then
    TZ=$(cat /etc/timezone)
  elif [[ -L /etc/localtime ]]; then
    TZ=$(readlink /etc/localtime | sed 's|.*/zoneinfo/||')
  else
    TZ=UTC
  fi
  export TZ
fi

# -b のビルドは run と分離して実行する。`run --build` はビルド失敗時に
# 既存の古いイメージでそのまま起動してしまう（fail-open）ため、
# build を独立させ set -e で失敗時に起動へ進まないようにする（fail-closed）。
if [[ $BUILD -eq 1 ]]; then
  CACHEBUST="$(date +%s)" CONTEXT="$WORKING_DIR" CLAUDE_CONTAINER_DIR="$RUN_DIR" \
    BUILD_CONTEXT_DIR="$BUILD_CONTEXT_DIR" \
    podman compose -f "$RUN_DIR/compose.yml" --in-pod false build claude-auth-workspace
fi

CONTEXT="$WORKING_DIR" CLAUDE_CONTAINER_DIR="$RUN_DIR" \
  BUILD_CONTEXT_DIR="$BUILD_CONTEXT_DIR" \
  podman compose -f "$RUN_DIR/compose.yml" --in-pod false run --rm claude-auth-workspace
