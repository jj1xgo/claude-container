FROM debian:stable

ARG CLAUDE_CODE_VERSION=latest
ARG TZ=UTC

# Set timezone before package install so tzdata uses it non-interactively
ENV TZ=${TZ}
ENV DEBIAN_FRONTEND=noninteractive

# Install ca-certificates first via HTTP (not pre-installed in debian:stable image)
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Switch to HTTPS now that ca-certificates is installed
RUN find /etc/apt -name '*.list' -o -name '*.sources' | \
    xargs sed -i 's|http://deb\.debian\.org|https://deb.debian.org|g'

# Install Claude Code dependencies (curl/jq for native installer; rest is dev convenience)
# iptables/bind9-dnsutils/iproute2/sudo are for init-firewall.sh (egress allowlist)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      curl git gh jq fzf unzip procps tzdata \
      iptables bind9-dnsutils iproute2 sudo && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Install project-specific apt packages
# Lines starting with "-" are excluded so packages.txt cannot inject apt options
COPY packages.txt /tmp/packages.txt
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      $(grep -Ev '^\s*(#|-|$)' /tmp/packages.txt | tr '\n' ' ') && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Install Python packages (skipped when requirements.txt has no entries).
# pip3 is not in the base image — projects using requirements.txt must add
# python3-pip to their packages.txt.
COPY requirements.txt /tmp/requirements.txt
RUN if grep -qE '^[[:space:]]*[^#[:space:]]' /tmp/requirements.txt; then \
      command -v pip3 >/dev/null || { \
        echo "ERROR: requirements.txt has entries but pip3 is not installed." >&2; \
        echo "Add python3-pip to .claude-container.d/packages.txt." >&2; \
        exit 1; }; \
      pip3 install -r /tmp/requirements.txt --break-system-packages; \
    fi

ENV DEVCONTAINER=true

# Create node user (UID 1000) — debian:stable doesn't have one
RUN groupadd --gid 1000 node \
  && useradd --uid 1000 --gid node --shell /bin/bash --create-home node

# Create workspace and config directories
RUN mkdir -p /workspace /home/node/.claude && \
  chown -R node:node /workspace /home/node/.claude

# Egress firewall assets: root-owned so the node user cannot alter the allowlist
# or the script at runtime. node may only run this exact script via sudo.
COPY init-firewall.sh /usr/local/bin/init-firewall.sh
COPY allowed-domains.txt /etc/claude-container/allowed-domains.txt
RUN chmod 755 /usr/local/bin/init-firewall.sh && \
  echo "node ALL=(root) NOPASSWD: /usr/local/bin/init-firewall.sh" > /etc/sudoers.d/node-firewall && \
  chmod 0440 /etc/sudoers.d/node-firewall

# GitHub meta snapshot, fetched by claude-container's stage_build_context() into the
# build context (not fetched here, so this step never touches the unauthenticated
# GitHub API rate limit itself). init-firewall.sh reads only this snapshot at runtime
# — it no longer does a live fetch. Root-owned like the other firewall assets.
COPY github-meta.json /etc/claude-container/github-meta.json
RUN jq -e '.web and .api and .git' /etc/claude-container/github-meta.json >/dev/null

WORKDIR /workspace
USER node

# Persist bash history to /workspace/.claude/bash_history
RUN echo "export PROMPT_COMMAND='mkdir -p /workspace/.claude && history -a'" >> /home/node/.bashrc \
  && echo "export HISTFILE=/workspace/.claude/bash_history" >> /home/node/.bashrc

COPY --chown=node:node entrypoint.sh /home/node/entrypoint.sh
RUN chmod +x /home/node/entrypoint.sh

# Cache-bust marker: value changes on every `-b` run so this layer (and below)
# is never reused from cache, guaranteeing the latest Claude Code is fetched.
ARG CACHEBUST=unknown

# Install Claude Code via official native installer (Recommended method)
# Installs to ~/.local/bin/claude (symlink) and ~/.local/share/claude (binary)
# Auto-updater is disabled via settings.json since container is --rm
RUN echo "cachebust=${CACHEBUST}" \
  && curl -fsSL https://claude.ai/install.sh | bash -s ${CLAUDE_CODE_VERSION}

# Add ~/.local/bin to PATH (where native installer places the symlink)
ENV PATH=/home/node/.local/bin:$PATH

CMD ["/home/node/entrypoint.sh"]
