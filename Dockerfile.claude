FROM debian:stable

ARG CLAUDE_CODE_VERSION=latest
ARG TZ=UTC

# Set timezone before package install so tzdata uses it non-interactively
ENV TZ=${TZ}
ENV DEBIAN_FRONTEND=noninteractive

# Install ca-certificates first via HTTP (not pre-installed in debian:stable image)
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Switch to HTTPS now that ca-certificates is installed
RUN find /etc/apt -name '*.list' -o -name '*.sources' | \
    xargs sed -i 's|http://deb\.debian\.org|https://deb.debian.org|g'

# Install Claude Code dependencies (curl/jq for native installer; rest is dev convenience)
# iptables/bind9-dnsutils/iproute2/sudo are for init-firewall.sh (egress allowlist)
# tini becomes PID1 (see ENTRYPOINT below): reaps children and keeps PID1
# signalable. With claude itself as PID1 (via exec in entrypoint.sh), children
# reparented to PID1 (e.g. the firewall refresh loop's sudo helpers, one per
# cycle) were never reaped and piled up as zombies, and when the workload
# wedged on exit (2026-07-02: a host kernel workqueue Oops left an unkillable
# D-state thread), the zombie PID1 could not be signalled at all — podman
# showed `crun kill ... failed` / "No such process" and the container stuck
# in "Stopping". tini cannot fix a kernel-side wedge, but keeps reaping and
# `podman stop` working. Kept here rather than in packages.txt so a project's
# own packages.txt can't silently drop it.
#
# xz-utils: for extracting the optional Node.js tarball (see node-version.txt
# below). Kept in this fixed layer rather than packages.txt for the same
# reason as tini — a project's own packages.txt can't silently drop it.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      curl git jq fzf unzip procps tzdata \
      iptables bind9-dnsutils iproute2 sudo tini xz-utils && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Install gh from GitHub's official apt repository instead of Debian's. Debian
# trixie ships gh 2.46.0, 46 releases behind upstream, which has a known-broken
# `gh pr view`/PR command regression across all repos (Debian bug #1119130,
# severity: serious) caused by the Projects (classic) API removal; issue
# commands are unaffected. Build-time network is unrestricted (see README.md's
# Security Model section), so fetching the signing key and repo metadata here
# never touches the runtime egress allowlist.
RUN mkdir -p -m 755 /etc/apt/keyrings && \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg -o /etc/apt/keyrings/githubcli-archive-keyring.gpg && \
    chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends gh && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Install project-specific apt packages
# Lines starting with "-" are excluded so packages.txt cannot inject apt options
COPY packages.txt /tmp/packages.txt
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      $(grep -Ev '^\s*(#|-|$)' /tmp/packages.txt | tr '\n' ' ') && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Install Python packages (skipped when requirements.txt has no entries).
# pip3 is not in the base image — projects using requirements.txt must add
# python3-pip to their packages.txt.
COPY requirements.txt /tmp/requirements.txt
RUN if grep -qE '^[[:space:]]*[^#[:space:]]' /tmp/requirements.txt; then \
      command -v pip3 >/dev/null || { \
        echo "ERROR: requirements.txt has entries but pip3 is not installed." >&2; \
        echo "Add python3-pip to .claude-container.d/packages.txt." >&2; \
        exit 1; }; \
      pip3 install -r /tmp/requirements.txt --break-system-packages; \
    fi

# Install a specific Node.js version from the official nodejs.org tarball when
# .claude-container.d/node-version.txt specifies one (e.g. "22.14.0"). apt on
# debian:stable has no path to Node 22.x (trixie ships 20.x, testing skips
# straight to 24.x), so projects needing 22.x declare just the bare version
# number here instead of a general-purpose build hook (see claude-container#3
# for the design rationale). Verifies the download against nodejs.org's own
# SHASUMS256.txt before extracting — fails the build (not silently) on any
# mismatch or network failure. Architecture is auto-detected (uname -m) since
# the build host may be x86_64 or arm64 (e.g. podman machine on Apple Silicon).
COPY node-version.txt /tmp/node-version.txt
RUN NODE_VERSION="$(tr -d '[:space:]' < /tmp/node-version.txt)" && \
    if [ -n "$NODE_VERSION" ]; then \
      echo "$NODE_VERSION" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$' || { \
        echo "ERROR: .claude-container.d/node-version.txt must contain a bare version like 22.14.0 (got: $NODE_VERSION)" >&2; exit 1; }; \
      case "$(uname -m)" in \
        x86_64) NODE_ARCH=x64 ;; \
        aarch64) NODE_ARCH=arm64 ;; \
        *) echo "ERROR: unsupported architecture $(uname -m) for node-version.txt" >&2; exit 1 ;; \
      esac; \
      cd /tmp && \
      curl -fsSLO "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-${NODE_ARCH}.tar.xz" && \
      curl -fsSLO "https://nodejs.org/dist/v${NODE_VERSION}/SHASUMS256.txt" && \
      grep " node-v${NODE_VERSION}-linux-${NODE_ARCH}.tar.xz\$" SHASUMS256.txt > node.sha256 && \
      [ -s node.sha256 ] && \
      sha256sum -c node.sha256 && \
      tar -xJf "node-v${NODE_VERSION}-linux-${NODE_ARCH}.tar.xz" -C /usr/local --strip-components=1 && \
      rm -f "node-v${NODE_VERSION}-linux-${NODE_ARCH}.tar.xz" SHASUMS256.txt node.sha256; \
    fi

# Install Codex CLI from npm when .claude-container.d/codex-version.txt specifies a
# version (e.g. "0.46.0") or the literal "latest". Optional, sibling design to
# node-version.txt above (see claude-container-ops#27 for the design rationale:
# declarative opt-in file, not a general-purpose build hook). Requires npm —
# projects opting in must also set node-version.txt (or add nodejs/npm via
# packages.txt). "latest" resolves via npm's own dist-tag on every install, same
# as Claude Code's own "latest" install below — CODEX_CACHEBUST (only bumped by
# claude-container when codex-version.txt says "latest") busts just this layer's
# cache so the reinstall actually happens on every `-b` rebuild.
COPY codex-version.txt /tmp/codex-version.txt
ARG CODEX_CACHEBUST=pinned
RUN echo "codex-cachebust=${CODEX_CACHEBUST}" && \
    CODEX_VERSION="$(tr -d '[:space:]' < /tmp/codex-version.txt)" && \
    if [ -n "$CODEX_VERSION" ]; then \
      echo "$CODEX_VERSION" | grep -qE '^([0-9]+\.[0-9]+\.[0-9]+|latest)$' || { \
        echo "ERROR: .claude-container.d/codex-version.txt must contain a bare version like 0.46.0 or the literal \"latest\" (got: $CODEX_VERSION)" >&2; exit 1; }; \
      command -v npm >/dev/null || { \
        echo "ERROR: codex-version.txt requires npm, which is not installed. Set .claude-container.d/node-version.txt (or add nodejs/npm to packages.txt)." >&2; exit 1; }; \
      npm install -g "@openai/codex@${CODEX_VERSION}"; \
    fi

ENV DEVCONTAINER=true

# Create node user (UID 1000) — debian:stable doesn't have one
RUN groupadd --gid 1000 node \
  && useradd --uid 1000 --gid node --shell /bin/bash --create-home node

# Create workspace and config directories
RUN mkdir -p /workspace /home/node/.claude && \
  chown -R node:node /workspace /home/node/.claude

# Egress firewall assets: root-owned so the node user cannot alter the allowlist
# or the script at runtime. node may only run this exact script via sudo.
COPY init-firewall.sh /usr/local/bin/init-firewall.sh
COPY allowed-domains.txt /etc/claude-container/allowed-domains.txt
RUN chmod 755 /usr/local/bin/init-firewall.sh && \
  echo "node ALL=(root) NOPASSWD: /usr/local/bin/init-firewall.sh" > /etc/sudoers.d/node-firewall && \
  chmod 0440 /etc/sudoers.d/node-firewall

# GIT_ASKPASS helper for the opt-in git push wiring (see entrypoint.sh). Root-owned,
# same pattern as init-firewall.sh, so the node user cannot alter it at runtime.
COPY git-askpass.sh /usr/local/bin/git-askpass.sh
RUN chmod 755 /usr/local/bin/git-askpass.sh

# GitHub meta snapshot, fetched by claude-container's stage_build_context() into the
# build context (not fetched here, so this step never touches the unauthenticated
# GitHub API rate limit itself). init-firewall.sh reads only this snapshot at runtime
# — it no longer does a live fetch. Root-owned like the other firewall assets.
COPY github-meta.json /etc/claude-container/github-meta.json
RUN jq -e '.web and .api and .git' /etc/claude-container/github-meta.json >/dev/null

WORKDIR /workspace
USER node

# Persist bash history to /workspace/.claude/bash_history
RUN echo "export PROMPT_COMMAND='mkdir -p /workspace/.claude && history -a'" >> /home/node/.bashrc \
  && echo "export HISTFILE=/workspace/.claude/bash_history" >> /home/node/.bashrc

COPY --chown=node:node entrypoint.sh /home/node/entrypoint.sh
RUN chmod +x /home/node/entrypoint.sh

# Cache-bust marker: value changes on every `-b` run so this layer (and below)
# is never reused from cache, guaranteeing the latest Claude Code is fetched.
ARG CACHEBUST=unknown

# Install Claude Code via official native installer (Recommended method)
# Installs to ~/.local/bin/claude (symlink) and ~/.local/share/claude (binary)
# Auto-updater is disabled via settings.json since container is --rm
RUN echo "cachebust=${CACHEBUST}" \
  && curl -fsSL https://claude.ai/install.sh | bash -s ${CLAUDE_CODE_VERSION}

# Add ~/.local/bin to PATH (where native installer places the symlink)
ENV PATH=/home/node/.local/bin:$PATH

# tini is PID1; entrypoint.sh (and the claude process it execs into) runs as its child.
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["/home/node/entrypoint.sh"]
